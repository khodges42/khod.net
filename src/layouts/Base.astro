---
import '../styles/global.css';
import Background from '../components/Background.astro';
import Nav from '../components/Nav.astro';
const { title = 'λ khodges42', description = 'systems / archives / notes / machines' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      try { if (localStorage.getItem('recruiterMode') === 'true') document.documentElement.classList.add('recruiter'); } catch (_) {}
    </script>
  </head>
  <body>
    <Background />
    <Nav />
    <main class="shell"><slot /></main>
  </body>
</html>
