---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
export async function getStaticPaths(){
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { id: post.id }, props: { post } }));
}
const { post } = Astro.props;
const { Content } = await render(post);
---
<Base title={`${post.data.title} / khodges42`} description={post.data.description}>
  <article class="pane prose" data-label={`/log/${post.id}`}>
    <p class="meta">{post.data.pubDate.toISOString().slice(0,10)} / {post.data.tags.map(t => <span class="tag">{t}</span>)}</p>
    <h1>{post.data.title}</h1>
    <Content />
  </article>
</Base>
